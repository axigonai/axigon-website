    { "source": "/api/auth/register", "destination": "/api/auth/signup.js" },
    { "source": "/api/auth/login", "destination": "/api/auth/login.js" },
    { "source": "/api/auth/me", "destination": "/api/auth/me.js" },
    { "source": "/api/auth/logout", "destination": "/api/auth/logout.js" },
    { "source": "/api/legal/chat", "destination": "/api/legal/chat.js" },
    { "source": "/api/legal/conversations", "destination": "/api/legal/conversations.js" },
    { "source": "/api/legal/messages", "destination": "/api/legal/messages.js" },
    { "source": "/api/admin/migrate-users", "destination": "/api/admin/migrate-users.js" },
    { "source": "/api/users/profile", "destination": "/api/users/profile.js" },
    { "source": "/api/agents", "destination": "/api/agents/index.js" },
